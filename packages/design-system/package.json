{
  "name": "@soroush.tech/design-system",
  "version": "0.1.0",
  "description": "Emotion + @soroush.tech/styled-system React component library — token-driven light/dark themes, layout primitives, forms, overlays, and a headless markdown editor/renderer.",
  "keywords": [
    "design-system",
    "react",
    "emotion",
    "styled-system",
    "components",
    "theme",
    "markdown",
    "typescript"
  ],
  "author": "Masoud Soroush <masoud@soroush.tech>",
  "license": "MIT",
  "homepage": "https://soroush.tech",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soroush-tech/core.git",
    "directory": "packages/design-system"
  },
  "bugs": {
    "url": "https://github.com/soroush-tech/core/issues"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/globalStyles.*"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./themes": "./src/themes.ts",
    "./globalStyles": "./src/globalStyles.ts",
    "./utils/styleCache": "./src/utils/styleCache.ts",
    "./hooks/useThemeMode": "./src/hooks/useThemeMode.ts",
    "./hooks/useCopyToClipboard": "./src/hooks/useCopyToClipboard.ts",
    "./utils/test/storiesArgs": "./src/utils/test/storiesArgs.ts",
    "./utils/test/storiesOptions": "./src/utils/test/storiesOptions.ts",
    "./utils/test/storiesToggle": "./src/utils/test/storiesToggle.tsx",
    "./*": "./src/*/index.ts"
  },
  "types": "./src/index.ts",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.mts",
          "default": "./dist/index.mjs"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      },
      "./*": {
        "import": {
          "types": "./dist/*.d.mts",
          "default": "./dist/*.mjs"
        },
        "require": {
          "types": "./dist/*.d.cts",
          "default": "./dist/*.cjs"
        }
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "typesVersions": {
      "*": {
        "*": [
          "./dist/*.d.cts"
        ]
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@soroush.tech/styled-system": "workspace:^",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "peerDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@tanstack/react-form": "^1.33.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-form": {
      "optional": true
    }
  },
  "devDependencies": {
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@soroush.tech/eslint-config": "workspace:*",
    "@storybook/react-vite": "^10.5.0",
    "@tanstack/react-form": "^1.33.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-storybook": "^10.5.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.5.0",
    "tsdown": "^0.22.7",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  }
}
