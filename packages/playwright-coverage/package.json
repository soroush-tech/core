{
  "name": "@soroush.tech/playwright-coverage",
  "version": "2.0.0",
  "description": "Collect per-test V8 code coverage from Playwright e2e runs and aggregate it to lcov via monocart-coverage-reports.",
  "keywords": [
    "playwright",
    "coverage",
    "code-coverage",
    "v8",
    "monocart",
    "lcov",
    "e2e",
    "testing"
  ],
  "author": "Masoud Soroush <masoud@soroush.tech>",
  "license": "MIT",
  "homepage": "https://soroush.tech/playwright-coverage/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soroush-tech/core.git",
    "directory": "packages/playwright-coverage"
  },
  "bugs": {
    "url": "https://github.com/soroush-tech/core/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.mts",
          "default": "./dist/index.mjs"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@playwright/test": "^1.61.1",
    "monocart-coverage-reports": "^2.12.12"
  },
  "dependencies": {
    "picomatch": "^4.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@soroush.tech/eslint-config": "workspace:*",
    "@types/node": "^26.1.1",
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "monocart-coverage-reports": "^2.12.12",
    "tsdown": "^0.22.7",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  }
}
