{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": [],
    "paths": {
      "@soroush.tech/markdown": ["../dist/index.d.mts"],
      "@soroush.tech/markdown/*": ["../dist/*.d.mts"]
    }
  },
  "include": ["."]
}
