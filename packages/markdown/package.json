{
  "name": "@soroush.tech/markdown",
  "version": "1.0.0",
  "description": "Headless, composable markdown editor + renderer for @soroush.tech/design-system — Control, Toolbar, Editor, and Preview built on react-markdown, remark-gfm, and rehype-highlight.",
  "keywords": [
    "markdown",
    "editor",
    "renderer",
    "react",
    "design-system",
    "remark",
    "rehype",
    "typescript"
  ],
  "author": "Masoud Soroush <masoud@soroush.tech>",
  "license": "MIT",
  "homepage": "https://soroush.tech",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soroush-tech/core.git",
    "directory": "packages/markdown"
  },
  "bugs": {
    "url": "https://github.com/soroush-tech/core/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*/index.ts"
  },
  "types": "./src/index.ts",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.mts",
          "default": "./dist/index.mjs"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      },
      "./*": {
        "import": {
          "types": "./dist/*.d.mts",
          "default": "./dist/*.mjs"
        },
        "require": {
          "types": "./dist/*.d.cts",
          "default": "./dist/*.cjs"
        }
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "typesVersions": {
      "*": {
        "*": [
          "./dist/*.d.cts"
        ]
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:types": "pnpm build && tsc -p type-tests/tsconfig.json",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "mermaid": "^11.16.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "peerDependencies": {
    "@soroush.tech/design-system": "workspace:^",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@soroush.tech/design-system": "workspace:*",
    "@soroush.tech/eslint-config": "workspace:*",
    "@soroush.tech/hooks": "workspace:*",
    "@storybook/react-vite": "^10.5.4",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-storybook": "^10.5.4",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "storybook": "^10.5.4",
    "tsdown": "^0.22.14",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  }
}
