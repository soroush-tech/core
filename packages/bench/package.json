{
  "name": "@soroush.tech/bench",
  "version": "1.0.1",
  "description": "Run A/B function and package-version benchmarks inside a CPU/RAM-pinned Docker sandbox for stable, low-noise numbers. Built on mitata.",
  "keywords": [
    "benchmark",
    "benchmarking",
    "mitata",
    "performance",
    "docker",
    "sandbox",
    "cpu-pinning",
    "typescript"
  ],
  "author": "Masoud Soroush <masoud@soroush.tech>",
  "license": "MIT",
  "homepage": "https://soroush.tech/bench/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soroush-tech/core.git",
    "directory": "packages/bench"
  },
  "bugs": {
    "url": "https://github.com/soroush-tech/core/issues"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "soroush-bench": "./dist/bin.mjs"
  },
  "files": [
    "dist",
    "Dockerfile"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.mts",
          "default": "./dist/index.mjs"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@soroush.tech/eslint-config": "workspace:*",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "mitata": "^1.0.34",
    "tsdown": "^0.22.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  }
}
