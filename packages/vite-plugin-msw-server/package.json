{
  "name": "@soroush.tech/vite-plugin-msw-server",
  "version": "1.0.0",
  "description": "Make server-side rendering deterministic in end-to-end tests: an msw/node mock server inside Vite, so SSR loaders and SSG prerendering resolve against your mocks instead of a live API.",
  "keywords": [
    "vite",
    "vite-plugin",
    "msw",
    "ssg",
    "ssr",
    "prerender",
    "mock",
    "vike",
    "testing"
  ],
  "author": "Masoud Soroush <masoud@soroush.tech>",
  "license": "MIT",
  "homepage": "https://soroush.tech/vite-plugin-msw-server/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soroush-tech/core.git",
    "directory": "packages/vite-plugin-msw-server"
  },
  "bugs": {
    "url": "https://github.com/soroush-tech/core/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.mts",
          "default": "./dist/index.mjs"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "vite": "^6 || ^7 || ^8"
  },
  "devDependencies": {
    "@soroush.tech/eslint-config": "workspace:*",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "tsdown": "^0.22.3",
    "typescript": "~6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
