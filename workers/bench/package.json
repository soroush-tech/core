{
  "name": "@soroush/bench-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "config:gen": "gen-wrangler WORKER_NAME BENCH_GH_APP_ID",
    "setup": "worker-setup-env",
    "predev": "pnpm config:gen",
    "dev": "wrangler dev --port 8788",
    "predeploy": "pnpm config:gen",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "hono": "^4.12.32",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260724.1",
    "@soroush.tech/eslint-config": "workspace:*",
    "@soroush.tech/wrangler-tools": "workspace:*",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.114.0"
  }
}
