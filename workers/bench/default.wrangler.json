{
  "name": "${WORKER_NAME}",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-18",
  "observability": { "enabled": true },
  "ratelimits": [
    { "name": "RATE_LIMITER", "namespace_id": "1001", "simple": { "limit": 3, "period": 60 } }
  ],
  "routes": [{ "pattern": "api.bench.soroush.tech", "custom_domain": true }],
  "vars": {
    "BENCH_GH_APP_ID": "${BENCH_GH_APP_ID}"
  }
}
