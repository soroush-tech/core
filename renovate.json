{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "rebaseWhen": "conflicted",
  "prConcurrentLimit": 1,
  "prHourlyLimit": 2,
  "labels": ["dependencies"],
  "semanticCommits": "enabled",
  "rangeStrategy": "bump",
  "enabledManagers": ["npm"],
  "separateMajorMinor": false,
  "separateMinorPatch": false,
  "lockFileMaintenance": {
    "enabled": false
  },
  "packageRules": [
    {
      "matchDepTypes": ["packageManager"],
      "enabled": false
    },
    {
      "matchUpdateTypes": ["pin"],
      "enabled": false
    },
    {
      "matchPackageNames": ["*"],
      "groupName": "all dependencies",
      "groupSlug": "all"
    },
    {
      "matchFileNames": ["apps/web/package.json"],
      "matchPackageNames": ["vite"],
      "allowedVersions": "<8.1.0",
      "description": "Hold apps/web Vite at 8.0.x: 8.1.x (Rolldown) drops top-level bindings in the Storybook production build, breaking Chromatic with 'ReferenceError: ... is not defined' (MSW checkGlobals). See https://github.com/storybookjs/storybook/issues/33789. Revisit when Storybook supports Vite 8/Rolldown."
    }
  ],
  "platformAutomerge": true
}
